<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_horizontal_padding"
        android:paddingTop="@dimen/screen_vertical_padding"
        android:paddingEnd="@dimen/screen_horizontal_padding"
        android:paddingBottom="@dimen/screen_vertical_padding">

        <!-- 타이틀 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="개인용 회원가입"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginBottom="32dp"/>

        <!-- 아이디(이메일) -->
        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="@dimen/form_field_height"
            android:hint="아이디(이메일)"
            android:inputType="textEmailAddress"
            android:background="@drawable/edit_text_bg"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="12dp"/>

        <!-- 비밀번호 -->
        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="@dimen/form_field_height"
            android:hint="비밀번호"
            android:inputType="textPassword"
            android:background="@drawable/edit_text_bg"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="12dp"/>

        <!-- 비밀번호 확인 -->
        <EditText
            android:id="@+id/etPasswordConfirm"
            android:layout_width="match_parent"
            android:layout_height="@dimen/form_field_height"
            android:hint="비밀번호 확인"
            android:inputType="textPassword"
            android:background="@drawable/edit_text_bg"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="12dp"/>

        <!-- 닉네임 -->
        <EditText
            android:id="@+id/etNickname"
            android:layout_width="match_parent"
            android:layout_height="@dimen/form_field_height"
            android:hint="닉네임"
            android:background="@drawable/edit_text_bg"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="12dp"/>

        <!-- 생년월일 -->
        <EditText
            android:id="@+id/etBirthdate"
            android:layout_width="match_parent"
            android:layout_height="@dimen/form_field_height"
            android:hint="생년월일 (YYYY.MM.DD)"
            android:inputType="number"
            android:background="@drawable/edit_text_bg"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="12dp"/>

        <!-- 전화번호 -->
        <EditText
            android:id="@+id/etPhone"
            android:layout_width="match_parent"
            android:layout_height="@dimen/form_field_height"
            android:hint="전화번호 (010-0000-0000)"
            android:inputType="phone"
            android:background="@drawable/edit_text_bg"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="12dp"/>

        <!-- 주소 검색 버튼 -->
        <Button
            android:id="@+id/btnAddress"
            android:layout_width="match_parent"
            android:layout_height="@dimen/form_field_height"
            android:text="주소 검색"
            android:textSize="16sp"
            android:backgroundTint="#E0E0E0"
            android:textColor="#333333"
            android:layout_marginBottom="8dp"/>

        <!-- 검색된 주소 표시 -->
        <EditText
            android:id="@+id/etAddress"
            android:layout_width="match_parent"
            android:layout_height="@dimen/form_field_height"
            android:hint="주소"
            android:background="@drawable/edit_text_bg"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="12dp"
            android:focusable="false"
            android:clickable="false"
            android:textColor="#333333"
            android:textColorHint="#999999"/>

        <!-- 상세주소 (선택) -->
        <EditText
            android:id="@+id/etAddressDetail"
            android:layout_width="match_parent"
            android:layout_height="@dimen/form_field_height"
            android:hint="상세주소 (선택)"
            android:background="@drawable/edit_text_bg"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="32dp"
            android:visibility="gone"/>

        <!-- 가입하기 버튼 -->
        <Button
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="@dimen/form_field_height"
            android:text="가입하기"
            android:textSize="16sp"
            android:backgroundTint="#4ECBAC"/>

    </LinearLayout>
</ScrollView>
