<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_horizontal_padding"
        android:paddingTop="@dimen/screen_vertical_padding"
        android:paddingEnd="@dimen/screen_horizontal_padding"
        android:paddingBottom="@dimen/screen_vertical_padding">

        <!-- 헤더 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_media_previous"
                android:background="?attr/selectableItemBackgroundBorderless"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="메뉴 수정"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"/>

            <View
                android:layout_width="36dp"
                android:layout_height="36dp"/>

        </LinearLayout>

        <!-- 메뉴 사진 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="메뉴 사진"
            android:textSize="14sp"
            android:layout_marginBottom="6dp"/>

        <ImageView
            android:id="@+id/iv_menu_image"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="#E0F2F1"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_camera"
            android:layout_marginBottom="16dp"/>

        <!-- 메뉴 이름 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="메뉴 이름"
            android:textSize="14sp"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/et_menu_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/white"
            android:padding="12dp"
            android:hint="메뉴 이름"
            android:layout_marginBottom="16dp"/>

        <!-- 가격 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="가격"
            android:textSize="14sp"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/et_menu_price"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/white"
            android:padding="12dp"
            android:hint="가격 (원)"
            android:inputType="number"
            android:layout_marginBottom="16dp"/>

        <!-- 카테고리 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="카테고리"
            android:textSize="14sp"
            android:layout_marginBottom="6dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_soju"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:minWidth="0dp"
                    android:text="소주"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btn_beer"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:minWidth="0dp"
                    android:text="맥주"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_food"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:minWidth="0dp"
                    android:text="안주"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btn_drink"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:minWidth="0dp"
                    android:text="음료"
                    android:textSize="13sp" />
            </LinearLayout>

        </LinearLayout>

        <!-- 품절 여부 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="품절 여부"
                android:textSize="14sp"/>

            <Switch
                android:id="@+id/switch_sold_out"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

        <!-- 수정하기 버튼 -->
        <Button
            android:id="@+id/btn_edit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="수정하기"
            android:backgroundTint="#4DB6AC"/>

    </LinearLayout>
</ScrollView>
