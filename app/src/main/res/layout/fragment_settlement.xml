                    <com.google.android.material.imageview.ShapeableImageView android:id="@+id/ivProfile4" android:layout_width="44dp" android:layout_height="44dp" android:scaleType="centerCrop" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" app:shapeAppearanceOverlay="@style/CircleShapeAppearance" tools:src="@drawable/ic_default" />
                    <TextView android:id="@+id/tvName4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="14dp" android:textColor="#333333" android:textSize="15sp" android:textStyle="bold" app:layout_constraintStart_toEndOf="@id/ivProfile4" app:layout_constraintTop_toTopOf="@id/ivProfile4" tools:text="참가자 4" />
                    <TextView android:id="@+id/tvDrinkCount4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:textColor="#999999" android:textSize="12sp" app:layout_constraintStart_toStartOf="@id/tvName4" app:layout_constraintTop_toBottomOf="@id/tvName4" tools:text="0잔" />
