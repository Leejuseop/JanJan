<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="@dimen/screen_horizontal_padding"
            android:paddingTop="@dimen/screen_vertical_padding"
            android:paddingEnd="@dimen/screen_horizontal_padding"
            android:paddingBottom="@dimen/screen_vertical_padding"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_max="@dimen/form_max_width">

    <!-- 로고 이미지 -->
    <ImageView
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:src="@drawable/janjan_logo"
        android:scaleType="fitCenter"
        android:layout_marginBottom="16dp"/>

    <!-- 앱 이름 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="잔잔"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginBottom="8dp"/>

    <!-- 슬로건 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="술자리를 더 편리하게"
        android:textSize="14sp"
        android:textColor="#888888"
        android:layout_marginBottom="48dp"/>

    <!-- 안내 텍스트 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="어떤 용도로 사용하시나요?"
        android:textSize="16sp"
        android:textColor="#333333"
        android:layout_marginBottom="24dp"/>

    <!-- 개인용 버튼 -->
    <Button
        android:id="@+id/btnPersonal"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="개인용"
        android:textSize="16sp"
        android:backgroundTint="#4ECBAC"
        android:layout_marginBottom="12dp"/>

    <!-- 사업자용 버튼 -->
    <Button
        android:id="@+id/btnBusiness"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="사업자용"
        android:textSize="16sp"
        android:backgroundTint="#4ECBAC"/>

        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
