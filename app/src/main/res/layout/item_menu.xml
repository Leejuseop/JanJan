<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:background="@android:color/white"
    android:layout_marginBottom="8dp">

    <ImageView
        android:id="@+id/iv_menu_image"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_default"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_menu_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:text="메뉴명"/>

            <TextView
                android:id="@+id/tv_sold_out"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="품절"
                android:textColor="#FF0000"
                android:textSize="12sp"
                android:layout_marginStart="8dp"
                android:visibility="gone"/>

        </LinearLayout>

        <TextView
            android:id="@+id/tv_menu_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#4DB6AC"
            android:text="0원"/>

        <TextView
            android:id="@+id/tv_menu_category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#999999"
            android:textSize="12sp"
            android:text="카테고리"/>

    </LinearLayout>

    <ImageButton
        android:id="@+id/btn_edit"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="center_vertical"
        android:layout_marginEnd="8dp"
        android:background="@drawable/bg_icon_button_mint_light"
        android:contentDescription="메뉴 수정"
        android:padding="10dp"
        android:src="@drawable/ic_edit_modern"
        app:tint="#4DB6AC" />

    <ImageButton
        android:id="@+id/btn_delete"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="center_vertical"
        android:background="@drawable/bg_icon_button_red_light"
        android:contentDescription="메뉴 삭제"
        android:padding="10dp"
        android:src="@drawable/ic_delete_modern"
        app:tint="#E05050" />

</LinearLayout>
