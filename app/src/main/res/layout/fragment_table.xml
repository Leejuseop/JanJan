<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- 헤더 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/iv_store_image"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/janjan_logo"
            android:scaleType="centerCrop"
            android:layout_marginEnd="10dp"/>

        <LinearLayout
            android:id="@+id/layout_store_profile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_store_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="가게 이름"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <ImageButton
                    android:id="@+id/btn_edit_name"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_icon_button_mint_light"
                    android:contentDescription="사업자 프로필 보기"
                    android:padding="7dp"
                    android:src="@drawable/ic_edit_modern"
                    app:tint="#4DB6AC" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="탭하여 사업자 프로필 보기"
                android:textSize="11sp"
                android:textColor="#999999"/>

        </LinearLayout>

    </LinearLayout>

    <!-- 통계 카드 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#E0F2F1"
            android:padding="12dp"
            android:layout_marginEnd="8dp"
            android:layout_marginStart="0dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="오늘 매출"
                android:textSize="12sp"
                android:textColor="#666666"/>

            <TextView
                android:id="@+id/tv_today_sales"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0원"
                android:textSize="18sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#E0F2F1"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="사용중 테이블"
                android:textSize="12sp"
                android:textColor="#666666"/>

            <TextView
                android:id="@+id/tv_table_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 / 0"
                android:textSize="18sp"
                android:textStyle="bold"/>

        </LinearLayout>

    </LinearLayout>

    <!-- 테이블 현황 헤더 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_table_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="테이블 현황 (0개)"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <ImageButton
            android:id="@+id/btn_settings"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_icon_button_mint"
            android:contentDescription="테이블 편집"
            android:padding="10dp"
            android:src="@drawable/ic_tune_modern"
            app:tint="@android:color/white" />

    </LinearLayout>

    <!-- 테이블 그리드 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_tables"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"/>

    <!-- 범례 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="12dp">

        <View
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="#4DB6AC"
            android:layout_marginEnd="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="사용중"
            android:textSize="12sp"
            android:layout_marginEnd="16dp"/>

        <View
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="#CCCCCC"
            android:layout_marginEnd="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="빈 테이블"
            android:textSize="12sp"/>

    </LinearLayout>

</LinearLayout>
